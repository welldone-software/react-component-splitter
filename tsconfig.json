{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2017",
		"outDir": "out",
		"rootDir": "src",
		"lib": [ "es2017" ],
		"sourceMap": true,
		"noImplicitAny": false,
		"noImplicitReturns": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"strict": true
	},
	"include": [
		"src"
	],
	"exclude": [
		"node_modules"
	],
	
}